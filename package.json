  "name": "green-bond-impact-reporter",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:start --workspace backend\" \"npm:start --workspace frontend\"",
